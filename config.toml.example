# NodeTalk Configuration File
# Copy this to config.toml and customize for your deployment.

[server]
# The public domain name of this node. Used for inter-node federation.
domain = "localhost"
# HTTP API and WebSocket port.
http_port = 8080
# Raw UDP port for voice routing (Wails desktop client only).
udp_port = 9090

[security]
# Master password for encrypting the database DEK via Argon2id (KEK derivation).
# If left empty, the server will generate a secure 32-char random string on first
# launch, print it to the terminal, and write it here automatically.
# IMPORTANT: Back this up. Losing it makes the database unrecoverable.
master_password = ""
# Number of hours before the authentication token and session expire.
token_expire_hours = 24

[database]
# Path where BadgerDB stores its data files.
path = "./data/db"

[rate_limit]
# Global rate limit: max requests per second per IP address.
global_rps = 100
# Strict rate limit for auth endpoints (/api/login, /api/register).
auth_rps = 5
